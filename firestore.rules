rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // Helper to check if user is editor
    function isEditor() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['editor', 'admin', 'elder', 'super_admin'];
    }

    // Helper to check if user is elder or super_admin
    function isElder() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['elder', 'super_admin'];
    }

    match /users/{userId} {
      // Allow users to read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      // Allow users to create their own document as 'viewer'
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.role == 'viewer';
      // Allow admins to read and write any user document
      allow read, write: if isAdmin();
    }

    match /hymns/{hymnId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }
    
    match /tags/{tagId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    match /services/{dateId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // Service Guide Template System (ADR-0008). The Page Library, Style Presets,
    // and Service Guide Templates are global, editor-authored content — public
    // read (the booklet is congregant-facing), editor+ write (same as weekly
    // editing). The frozen per-week snapshot lives on services/{date}.guide and
    // is covered by the services rule above. Components ship in code, not here.
    match /style_presets/{presetId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }
    match /page_templates/{templateId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }
    match /guide_templates/{templateId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }
    // Asset Library — reusable images (logos, QR codes) referenced by URL in pages.
    // Bytes live in Storage; this holds metadata + the public download URL.
    match /guide_assets/{assetId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    match /people/{personId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
      
      match /involvement/{involvementId} {
        allow read: if true;
        allow create, update, delete: if isEditor();
      }

      match /pastoral_prayer_history/{historyId} {
        allow read: if true;
        allow create, update, delete: if isEditor();
      }

      // Prayer Requests are sensitive: visible to Elders/super admins only.
      // Keyed by service date so they line up with the order of service.
      match /prayer_requests/{requestId} {
        allow read, write: if isElder();
      }
    }

    // Allow collection group queries for pastoral_prayer_history
    match /{path=**}/pastoral_prayer_history/{historyId} {
      allow read: if true;
    }

    // Allow collection group queries for involvement (used by service injection
    // to re-key role assignments when services are shifted to a later Sunday)
    match /{path=**}/involvement/{involvementId} {
      allow read: if true;
    }

    match /people_tags/{tagId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // Shepherding System — elders and super_admins only
    match /shepherding_tags/{tagId} {
      allow read, write: if isElder();
    }

    match /shepherding_views/{viewId} {
      allow read, write: if isElder();
    }

    match /shepherding_reminders/{reminderId} {
      allow read, write: if isElder();
    }

    match /elder_meetings/{meetingId} {
      allow read, write: if isElder();
    }

    match /elder_documents/{docId} {
      allow read, write: if isElder();
    }

    match /elder_document_structure/{docId} {
      allow read, write: if isElder();
    }

    match /people/{personId}/shepherding_notes/{noteId} {
      allow read, write: if isElder();
    }

    match /people/{personId}/shepherding_activity/{activityId} {
      allow read, write: if isElder();
    }

    // Collection group query for shepherding_notes (used by People list page)
    match /{path=**}/shepherding_notes/{noteId} {
      allow read: if isElder();
    }

    // Inbound replies to SMS test texts. Written only by the smsInbound webhook
    // (admin SDK, bypasses rules); admins read and clear them from the Admin
    // Dashboard. No client writes.
    match /sms_test_replies/{replyId} {
      allow read, delete: if isAdmin();
    }

    // App-wide config edited from the Admin Dashboard (e.g. the prayer-request
    // SMS message templates and the automation kill switch). The server reads
    // these via the admin SDK.
    match /app_config/{configId} {
      allow read, write: if isAdmin();
    }

    // Outbound SMS log — written only by the server (admin SDK) and read by
    // admins for the audit/status readout. No client writes.
    match /sms_messages/{messageId} {
      allow read: if isAdmin();
    }
  }
}
